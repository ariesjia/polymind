# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# JWT signing (required for auth; generate a random string for production)
JWT_SECRET=your-secret-key-change-in-production

# WalletConnect (免费从 https://cloud.walletconnect.com/ 获取，用于 RainbowKit 扫码连接)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# OpenAI / MiniMax (for AI analysis backend)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=

# Tavily (optional, for agent search tool; user's key in settings takes precedence)
TAVILY_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

